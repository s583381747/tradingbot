// ============================================================================
// 日内趋势跟随策略 - 20 EMA 回撤系统
// Intraday Trend Following Strategy - 20 EMA Pullback System
//
// 基于 @rijindoudoujin 频道 35 个视频 AI 分析提取的交易系统
// 核心逻辑: 趋势确认 → 等待回撤至 20EMA/VWAP → 突破入场 → 趋势跟踪出场
// ============================================================================
//@version=5
strategy("日内趋势跟随 - 20EMA回撤系统",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.01,
     slippage=1,
     process_orders_on_close=false,
     calc_on_every_tick=false,
     max_bars_back=500)

// ============================================================================
// 一、参数设置
// ============================================================================

// --- 均线参数 ---
emaLen        = input.int(20,    "EMA 周期",          minval=5,   maxval=100, group="均线设置")
emaSlowLen    = input.int(40,    "慢速 EMA 周期",      minval=20,  maxval=200, group="均线设置")
emaFilterLen  = input.int(60,    "趋势过滤 EMA 周期",   minval=30,  maxval=300, group="均线设置")

// --- VWAP ---
useVwap       = input.bool(true, "使用 VWAP 辅助确认",  group="VWAP设置")

// --- 趋势确认参数 ---
trendBars     = input.int(5,     "趋势确认K线数",       minval=2,   maxval=20,  group="趋势确认")
trendAtrMult  = input.float(1.0, "趋势强度ATR倍数",     minval=0.1, maxval=5.0, step=0.1, group="趋势确认")

// --- 回撤参数 ---
pullbackTol   = input.float(0.3, "回撤容差(ATR倍数)",   minval=0.1, maxval=2.0, step=0.1, group="回撤设置")
maxPullbackBars = input.int(8,   "最大回撤K线数",       minval=2,   maxval=20,  group="回撤设置")

// --- 成交量确认 ---
useVolFilter  = input.bool(true, "使用成交量过滤",      group="成交量")
volMaLen      = input.int(20,    "成交量均线周期",       minval=5,   maxval=50,  group="成交量")
volThresh     = input.float(0.8, "最低成交量倍数",       minval=0.3, maxval=3.0, step=0.1, group="成交量")

// --- K线形态确认 ---
useWickFilter = input.bool(true, "使用影线拒绝确认",     group="K线形态")
wickRatio     = input.float(1.5, "影线/实体比率阈值",    minval=0.5, maxval=5.0, step=0.1, group="K线形态")

// --- 止损止盈 ---
slType        = input.string("回撤摆动点", "止损方式", options=["回撤摆动点", "ATR倍数", "固定百分比"], group="风险管理")
slAtrMult     = input.float(1.5, "止损ATR倍数",        minval=0.5, maxval=5.0, step=0.1, group="风险管理")
slFixedPct    = input.float(0.5, "固定止损百分比",       minval=0.1, maxval=5.0, step=0.1, group="风险管理")
useTrailStop  = input.bool(true, "使用追踪止损(沿EMA)", group="风险管理")
trailOffset   = input.float(0.3, "追踪止损偏移(ATR倍数)", minval=0.1, maxval=3.0, step=0.1, group="风险管理")
tpAtrMult     = input.float(3.0, "止盈ATR倍数",        minval=1.0, maxval=10.0, step=0.5, group="风险管理")
useTP         = input.bool(false, "使用固定止盈",       group="风险管理")
rrRatio       = input.float(2.0, "风险回报比",          minval=1.0, maxval=10.0, step=0.5, group="风险管理")

// --- 分批止盈 ---
usePartialTP  = input.bool(true,  "使用分批止盈",       group="分批止盈")
tp1Pct        = input.float(50.0, "第一次止盈仓位%",     minval=10,  maxval=90,  step=10, group="分批止盈")
tp1RR         = input.float(1.5,  "第一次止盈RR倍数",    minval=0.5, maxval=5.0, step=0.5, group="分批止盈")
tp2RR         = input.float(3.0,  "第二次止盈RR倍数",    minval=1.0, maxval=10.0, step=0.5, group="分批止盈")

// --- 时间过滤 ---
useTimeFilter = input.bool(true,  "使用时间过滤",       group="时间过滤")
startHour     = input.int(10,     "开始交易时间(时)",    minval=0,   maxval=23,  group="时间过滤")
startMin      = input.int(30,     "开始交易时间(分)",    minval=0,   maxval=59,  group="时间过滤")
endHour       = input.int(15,     "停止开仓时间(时)",    minval=0,   maxval=23,  group="时间过滤")
endMin        = input.int(30,     "停止开仓时间(分)",    minval=0,   maxval=59,  group="时间过滤")
closeHour     = input.int(15,     "收盘平仓时间(时)",    minval=0,   maxval=23,  group="时间过滤")
closeMin      = input.int(55,     "收盘平仓时间(分)",    minval=0,   maxval=59,  group="时间过滤")

// --- Open Range Breakout ---
useORB        = input.bool(true,  "使用ORB过滤(避开宽幅第一根K线)", group="ORB过滤")
orbBars       = input.int(6,      "ORB观察K线数(5分钟图=30分钟)",  minval=1, maxval=24, group="ORB过滤")
orbAtrMult    = input.float(2.0,  "ORB宽幅阈值(ATR倍数)",         minval=0.5, maxval=5.0, step=0.1, group="ORB过滤")

// --- 交易方向 ---
tradeDir      = input.string("双向", "交易方向", options=["双向", "仅做多", "仅做空"], group="交易方向")

// --- 每日最大交易次数 ---
maxDailyTrades = input.int(3, "每日最大交易次数", minval=1, maxval=10, group="风险管理")

// ============================================================================
// 二、指标计算
// ============================================================================

// --- 均线 ---
ema20  = ta.ema(close, emaLen)
ema40  = ta.ema(close, emaSlowLen)
ema60  = ta.ema(close, emaFilterLen)

// --- ATR ---
atrVal = ta.atr(14)

// --- VWAP ---
vwapVal = useVwap ? ta.vwap(hlc3) : ema20

// --- 成交量均线 ---
volMa  = ta.sma(volume, volMaLen)

// --- 日内时间判断 ---
currentTime  = hour * 60 + minute
startTime    = startHour * 60 + startMin
endTime      = endHour * 60 + endMin
closeTime    = closeHour * 60 + closeMin
inTradeWindow = (not useTimeFilter) or (currentTime >= startTime and currentTime <= endTime)
isCloseTime   = useTimeFilter and (currentTime >= closeTime)

// --- 新交易日判断 ---
isNewDay = ta.change(time("D")) != 0

// --- 每日交易次数追踪 ---
var int dailyTradeCount = 0
if isNewDay
    dailyTradeCount := 0
canTradeToday = dailyTradeCount < maxDailyTrades

// ============================================================================
// 三、趋势判断
// ============================================================================

// 多头趋势: 价格在EMA20上方, EMA20在EMA40上方, EMA40在EMA60上方 (多头排列)
bullTrend = ema20 > ema40 and close > ema20
// 更严格的多头趋势: 加上EMA60过滤
bullTrendStrong = ema20 > ema40 and ema40 > ema60 and close > ema20

// 空头趋势: 价格在EMA20下方, EMA20在EMA40下方 (空头排列)
bearTrend = ema20 < ema40 and close < ema20
// 更严格的空头趋势
bearTrendStrong = ema20 < ema40 and ema40 < ema60 and close < ema20

// 趋势强度: 最近N根K线的价格位移超过ATR阈值
trendDisplacement = math.abs(close - close[trendBars])
isTrendStrong = trendDisplacement > atrVal * trendAtrMult

// 最终趋势信号
isBullish = bullTrend and isTrendStrong
isBearish = bearTrend and isTrendStrong

// ============================================================================
// 四、回撤检测 - 价格触及20EMA/VWAP
// ============================================================================

// 价格接近EMA20 (在ATR容差范围内)
nearEma20  = math.abs(low - ema20) <= atrVal * pullbackTol or
             math.abs(high - ema20) <= atrVal * pullbackTol or
             (low <= ema20 and high >= ema20)

// 价格接近VWAP
nearVwap   = useVwap and (math.abs(low - vwapVal) <= atrVal * pullbackTol or
             math.abs(high - vwapVal) <= atrVal * pullbackTol or
             (low <= vwapVal and high >= vwapVal))

// 回撤触及EMA或VWAP
isPullback = nearEma20 or nearVwap

// 回撤窗口: 最近N根K线内出现过回撤
var int barsSincePullback = 999
if isPullback
    barsSincePullback := 0
else
    barsSincePullback := barsSincePullback + 1

inPullbackWindow = barsSincePullback <= maxPullbackBars and barsSincePullback > 0

// ============================================================================
// 五、入场确认信号
// ============================================================================

// --- 突破确认 ---
// 做多: 价格突破回撤期间的局部高点
prevSwingHigh = ta.highest(high, maxPullbackBars)
breakoutLong  = close > high[1] and close > ema20

// 做空: 价格跌破回撤期间的局部低点
prevSwingLow  = ta.lowest(low, maxPullbackBars)
breakoutShort = close < low[1] and close < ema20

// --- 成交量确认 ---
volConfirm = (not useVolFilter) or (volume >= volMa * volThresh)

// --- 影线拒绝确认 (针对做空: 长上影线表示阻力) ---
bodySize    = math.abs(close - open)
upperWick   = high - math.max(close, open)
lowerWick   = math.min(close, open) - low

// 做空时: 回撤K线有长上影线 (被20EMA/VWAP阻挡)
bearishWick = useWickFilter ? (upperWick > bodySize * wickRatio) : true
// 做多时: 回撤K线有长下影线 (被20EMA/VWAP支撑)
bullishWick = useWickFilter ? (lowerWick > bodySize * wickRatio) : true

// 检查回撤窗口内是否出现过拒绝形态
var bool hadBullishWick = false
var bool hadBearishWick = false
if isPullback
    hadBullishWick := false
    hadBearishWick := false
if bullishWick and barsSincePullback <= maxPullbackBars
    hadBullishWick := true
if bearishWick and barsSincePullback <= maxPullbackBars
    hadBearishWick := true

wickConfirmLong  = (not useWickFilter) or hadBullishWick
wickConfirmShort = (not useWickFilter) or hadBearishWick

// --- ORB 过滤: 避开开盘第一根K线过长的日子 ---
var float orbHigh = na
var float orbLow  = na
var bool  orbWide = false

if isNewDay
    orbHigh := high
    orbLow  := low
    orbWide := false

// 追踪ORB区间
orbBarCount = ta.barssince(isNewDay)
if orbBarCount > 0 and orbBarCount <= orbBars
    orbHigh := math.max(nz(orbHigh), high)
    orbLow  := math.min(nz(orbLow), low)

if orbBarCount == orbBars
    orbRange = nz(orbHigh) - nz(orbLow)
    orbWide  := orbRange > atrVal * orbAtrMult

orbClear = (not useORB) or (not orbWide) or (orbBarCount > orbBars * 2)

// ============================================================================
// 六、完整入场条件
// ============================================================================

// --- 做多入场 ---
longCondition = isBullish and              // 1. 确认上升趋势
                 inPullbackWindow and       // 2. 最近回撤过EMA/VWAP
                 breakoutLong and           // 3. 突破回撤高点
                 volConfirm and             // 4. 成交量确认
                 wickConfirmLong and         // 5. K线形态确认
                 inTradeWindow and          // 6. 在交易时间窗口内
                 canTradeToday and          // 7. 未超过每日交易限制
                 orbClear and              // 8. ORB过滤通过
                 (tradeDir != "仅做空") and  // 9. 允许做多
                 strategy.position_size == 0 // 10. 当前无持仓

// --- 做空入场 ---
shortCondition = isBearish and
                  inPullbackWindow and
                  breakoutShort and
                  volConfirm and
                  wickConfirmShort and
                  inTradeWindow and
                  canTradeToday and
                  orbClear and
                  (tradeDir != "仅做多") and
                  strategy.position_size == 0

// ============================================================================
// 七、止损计算
// ============================================================================

// 回撤期间的摆动低点/高点
pullbackLow  = ta.lowest(low, maxPullbackBars + 1)
pullbackHigh = ta.highest(high, maxPullbackBars + 1)

// 持仓跟踪变量
var float entryPrice   = na
var float stopLoss     = na
var float takeProfit   = na
var float trailStop    = na
var bool  tp1Hit       = false
var float initialRisk  = na

// ============================================================================
// 八、执行交易
// ============================================================================

// --- 做多入场 ---
if longCondition
    entryPrice := close

    // 计算止损
    if slType == "回撤摆动点"
        stopLoss := pullbackLow - atrVal * 0.1  // 摆动低点下方留一点缓冲
    else if slType == "ATR倍数"
        stopLoss := close - atrVal * slAtrMult
    else
        stopLoss := close * (1 - slFixedPct / 100)

    initialRisk := close - stopLoss

    // 计算止盈
    if useTP
        takeProfit := close + initialRisk * rrRatio
    else
        takeProfit := close + atrVal * tpAtrMult

    trailStop := stopLoss
    tp1Hit    := false
    dailyTradeCount := dailyTradeCount + 1

    strategy.entry("做多", strategy.long)
    strategy.exit("多头止损", "做多", stop=stopLoss)

// --- 做空入场 ---
if shortCondition
    entryPrice := close

    if slType == "回撤摆动点"
        stopLoss := pullbackHigh + atrVal * 0.1
    else if slType == "ATR倍数"
        stopLoss := close + atrVal * slAtrMult
    else
        stopLoss := close * (1 + slFixedPct / 100)

    initialRisk := stopLoss - close

    if useTP
        takeProfit := close - initialRisk * rrRatio
    else
        takeProfit := close - atrVal * tpAtrMult

    trailStop := stopLoss
    tp1Hit    := false
    dailyTradeCount := dailyTradeCount + 1

    strategy.entry("做空", strategy.short)
    strategy.exit("空头止损", "做空", stop=stopLoss)

// ============================================================================
// 九、持仓管理 - 追踪止损 & 分批止盈
// ============================================================================

if strategy.position_size > 0  // 持有多头
    // 追踪止损: 沿EMA20移动
    if useTrailStop
        newTrail = ema20 - atrVal * trailOffset
        if newTrail > trailStop and newTrail < close
            trailStop := newTrail
            strategy.exit("多头追踪止损", "做多", stop=trailStop)

    // 分批止盈
    if usePartialTP and not tp1Hit and not na(initialRisk)
        tp1Level = entryPrice + initialRisk * tp1RR
        if close >= tp1Level
            strategy.close("做多", comment="分批止盈1", qty_percent=tp1Pct)
            tp1Hit := true
            // 止损移至盈亏平衡点
            trailStop := entryPrice
            strategy.exit("多头保本止损", "做多", stop=trailStop)

    // 最终止盈
    if useTP and close >= takeProfit
        strategy.close("做多", comment="止盈")

if strategy.position_size < 0  // 持有空头
    if useTrailStop
        newTrail = ema20 + atrVal * trailOffset
        if newTrail < trailStop and newTrail > close
            trailStop := newTrail
            strategy.exit("空头追踪止损", "做空", stop=trailStop)

    if usePartialTP and not tp1Hit and not na(initialRisk)
        tp1Level = entryPrice - initialRisk * tp1RR
        if close <= tp1Level
            strategy.close("做空", comment="分批止盈1", qty_percent=tp1Pct)
            tp1Hit := true
            trailStop := entryPrice
            strategy.exit("空头保本止损", "做空", stop=trailStop)

    if useTP and close <= takeProfit
        strategy.close("做空", comment="止盈")

// --- 收盘前强制平仓 (日内交易核心规则) ---
if isCloseTime and strategy.position_size != 0
    strategy.close_all(comment="收盘平仓")

// ============================================================================
// 十、图表绘制
// ============================================================================

// --- 均线 ---
plot(ema20, "EMA 20", color=color.new(color.orange, 0), linewidth=2)
plot(ema40, "EMA 40", color=color.new(color.blue, 30), linewidth=1)
plot(ema60, "EMA 60", color=color.new(color.purple, 30), linewidth=1)

// --- VWAP ---
plot(useVwap ? vwapVal : na, "VWAP", color=color.new(color.teal, 0), linewidth=2, style=plot.style_stepline)

// --- 趋势背景 ---
bgColor = isBullish ? color.new(color.green, 92) : isBearish ? color.new(color.red, 92) : na
bgcolor(bgColor, title="趋势背景")

// --- 回撤标记 ---
plotshape(isPullback and isBullish, "多头回撤", shape.circle, location.belowbar, color.new(color.green, 50), size=size.tiny)
plotshape(isPullback and isBearish, "空头回撤", shape.circle, location.abovebar, color.new(color.red, 50), size=size.tiny)

// --- 入场信号 ---
plotshape(longCondition,  "做多信号", shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.normal)
plotshape(shortCondition, "做空信号", shape.triangledown, location.abovebar, color.new(color.red, 0),   size=size.normal)

// --- 止损线 ---
slPlot = strategy.position_size != 0 ? (useTrailStop ? trailStop : stopLoss) : na
plot(slPlot, "止损线", color=color.new(color.red, 0), linewidth=1, style=plot.style_linebr)

// --- 止盈线 ---
tpPlot = strategy.position_size != 0 and useTP ? takeProfit : na
plot(tpPlot, "止盈线", color=color.new(color.green, 0), linewidth=1, style=plot.style_linebr)

// --- ORB区间 ---
orbHighPlot = useORB and orbBarCount <= orbBars * 2 ? orbHigh : na
orbLowPlot  = useORB and orbBarCount <= orbBars * 2 ? orbLow : na
plot(orbHighPlot, "ORB高", color=color.new(color.gray, 50), linewidth=1, style=plot.style_stepline)
plot(orbLowPlot,  "ORB低", color=color.new(color.gray, 50), linewidth=1, style=plot.style_stepline)

// ============================================================================
// 十一、信息面板
// ============================================================================

var table infoPanel = table.new(position.top_right, 2, 12,
     bgcolor=color.new(color.black, 80),
     border_width=1,
     border_color=color.new(color.gray, 60))

if barstate.islast
    table.cell(infoPanel, 0, 0, "指标", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 0, "状态", text_color=color.white, text_size=size.small)

    // 趋势状态
    trendText = isBullish ? "🔼 多头" : isBearish ? "🔽 空头" : "➡️ 震荡"
    trendColor = isBullish ? color.green : isBearish ? color.red : color.gray
    table.cell(infoPanel, 0, 1, "趋势", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 1, trendText, text_color=trendColor, text_size=size.small)

    // EMA排列
    emaOrder = ema20 > ema40 and ema40 > ema60 ? "多头排列" : ema20 < ema40 and ema40 < ema60 ? "空头排列" : "交叉"
    table.cell(infoPanel, 0, 2, "均线", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 2, emaOrder, text_color=color.white, text_size=size.small)

    // 回撤状态
    pbText = isPullback ? "触及中" : inPullbackWindow ? "窗口内(" + str.tostring(barsSincePullback) + ")" : "等待"
    table.cell(infoPanel, 0, 3, "回撤", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 3, pbText, text_color=isPullback ? color.yellow : color.white, text_size=size.small)

    // 成交量
    volText = volume >= volMa * volThresh ? "充足" : "不足"
    volColor = volume >= volMa * volThresh ? color.green : color.red
    table.cell(infoPanel, 0, 4, "成交量", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 4, volText, text_color=volColor, text_size=size.small)

    // ATR
    table.cell(infoPanel, 0, 5, "ATR", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 5, str.tostring(atrVal, "#.##"), text_color=color.white, text_size=size.small)

    // 持仓状态
    posText = strategy.position_size > 0 ? "多头" : strategy.position_size < 0 ? "空头" : "空仓"
    posColor = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray
    table.cell(infoPanel, 0, 6, "持仓", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 6, posText, text_color=posColor, text_size=size.small)

    // 止损价
    slText = not na(stopLoss) and strategy.position_size != 0 ? str.tostring(trailStop, "#.##") : "-"
    table.cell(infoPanel, 0, 7, "止损", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 7, slText, text_color=color.red, text_size=size.small)

    // 今日交易次数
    table.cell(infoPanel, 0, 8, "今日交易", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 8, str.tostring(dailyTradeCount) + "/" + str.tostring(maxDailyTrades), text_color=color.white, text_size=size.small)

    // ORB状态
    orbText = not useORB ? "关闭" : orbWide ? "宽幅(避开)" : "正常"
    orbColor = orbWide ? color.red : color.green
    table.cell(infoPanel, 0, 9, "ORB", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 9, orbText, text_color=orbColor, text_size=size.small)

    // 交易时间
    timeText = inTradeWindow ? "交易中" : isCloseTime ? "收盘" : "等待"
    table.cell(infoPanel, 0, 10, "时间", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 10, timeText, text_color=inTradeWindow ? color.green : color.yellow, text_size=size.small)

// ============================================================================
// 十二、报警条件
// ============================================================================

alertcondition(longCondition,  "做多入场信号", "趋势跟随做多: 价格回撤20EMA后突破,趋势确认")
alertcondition(shortCondition, "做空入场信号", "趋势跟随做空: 价格回撤20EMA后突破,趋势确认")
alertcondition(isPullback and isBullish, "多头回撤提醒", "价格回撤至20EMA/VWAP附近,多头趋势中")
alertcondition(isPullback and isBearish, "空头回撤提醒", "价格回撤至20EMA/VWAP附近,空头趋势中")
