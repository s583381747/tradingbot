// ============================================================================
// EMA20 Trend Following — Plan F (Production)
//
// Logic (matches strategy_final.py exactly):
//   TREND:  close > EMA20 > EMA50 (bull) or close < EMA20 < EMA50 (bear)
//   TOUCH:  wick within 0.15*ATR of EMA20
//   BOUNCE: next bar close > touch bar high
//   ENTRY:  signal line = touch_high + offset (stop order, 3 bars valid)
//   STOP:   touch_low - 0.3*ATR
//   LOCK:   20% at 0.3R → move stop to breakeven
//   RUNNER: 80% Chandelier trail: highest_high(40) - 1.0*ATR
//   DAILY:  2.5R loss limit per day
//
// Validated: PF=2.55, +33%, 4431 trades, WR=77%, MaxDD=0.33%
// ============================================================================
//@version=6
strategy("EMA20 Plan F",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=0.005,
     slippage=0,
     process_orders_on_close=false,
     calc_on_every_tick=false,
     max_bars_back=500,
     pyramiding=0)

// ============================================================================
// PARAMETERS
// ============================================================================

// --- Core Indicators ---
emaFastLen    = input.int(20,      "EMA Fast",            minval=5,   maxval=100,  group="Indicators")
emaSlowLen    = input.int(50,      "EMA Slow",            minval=20,  maxval=200,  group="Indicators")
atrLen        = input.int(14,      "ATR Period",          minval=5,   maxval=30,   group="Indicators")

// --- Touch Detection ---
touchTol      = input.float(0.15,  "Touch Tolerance (xATR)", minval=0.05, maxval=1.0, step=0.05, group="Entry")
touchBelow    = input.float(0.5,   "Touch Below Max (xATR)", minval=0.1,  maxval=2.0, step=0.1,  group="Entry")
signalOffset  = input.float(0.05,  "Signal Offset ($)",      minval=0.01, maxval=0.50, step=0.01, group="Entry")
stopBuffer    = input.float(0.3,   "Stop Buffer (xATR)",     minval=0.1,  maxval=2.0,  step=0.1,  group="Entry")
signalBars    = input.int(3,       "Signal Valid Bars",       minval=1,    maxval=10,   group="Entry")

// --- Exit: Lock + Chandelier ---
lockRR        = input.float(0.3,   "Lock R:R",            minval=0.1,  maxval=2.0,  step=0.1,  group="Exit")
lockPct       = input.float(20,    "Lock Position %",     minval=5,    maxval=50,   step=5,    group="Exit")
chandBars     = input.int(40,      "Chandelier Lookback", minval=10,   maxval=100,  group="Exit")
chandMult     = input.float(1.0,   "Chandelier ATR Mult", minval=0.5,  maxval=3.0,  step=0.1,  group="Exit")

// --- Risk ---
riskPct       = input.float(1.0,   "Risk Per Trade %",    minval=0.1,  maxval=5.0,  step=0.1,  group="Risk")
maxPosPct     = input.float(25,    "Max Position %",      minval=5,    maxval=50,   step=5,    group="Risk")
dailyRLimit   = input.float(2.5,   "Daily R Limit",       minval=1.0,  maxval=10.0, step=0.5,  group="Risk")
maxHoldBars   = input.int(180,     "Max Hold Bars",       minval=30,   maxval=500,  group="Risk")

// --- Session ---
noEntryHour   = input.int(15,      "No Entry After (H)",  minval=0, maxval=23, group="Session")
noEntryMin    = input.int(30,      "No Entry After (M)",  minval=0, maxval=59, group="Session")
closeHour     = input.int(15,      "Force Close (H)",     minval=0, maxval=23, group="Session")
closeMin      = input.int(58,      "Force Close (M)",     minval=0, maxval=59, group="Session")

// --- Direction ---
tradeDir      = input.string("Both", "Direction", options=["Both", "Long Only", "Short Only"], group="Direction")

// ============================================================================
// INDICATORS
// ============================================================================

ema20  = ta.ema(close, emaFastLen)
ema50  = ta.ema(close, emaSlowLen)
atrVal = ta.atr(atrLen)

// ============================================================================
// SESSION
// ============================================================================

currentMins    = hour * 60 + minute
noEntryTime    = noEntryHour * 60 + noEntryMin
forceCloseTime = closeHour * 60 + closeMin
pastEntry      = currentMins >= noEntryTime
pastClose      = currentMins >= forceCloseTime
isNewDay       = ta.change(time("D")) != 0

// ============================================================================
// DAILY R TRACKING
// ============================================================================

var float dailyRLoss  = 0.0
var float dailyStart  = 0.0

if isNewDay
    dailyRLoss := 0.0
    dailyStart := strategy.equity

dailyLimitHit = dailyRLoss >= dailyRLimit

// ============================================================================
// STATE MACHINE
// ============================================================================

// Touch/Bounce/Signal detection state
var int   touchBar     = -1     // bar_index of touch
var float touchHigh    = 0.0
var float touchLow     = 0.0
var float touchATR     = 0.0
var int   touchDir     = 0      // 1=long touch, -1=short touch

var int   bounceBar    = -1     // bar_index of bounce confirmation
var float signalPrice  = 0.0    // entry price (stop order)
var float stopPrice    = 0.0    // initial stop
var float tradeRisk    = 0.0    // |signal - stop|
var int   signalDir    = 0      // direction of pending signal
var int   signalExpiry = -1     // bar_index when signal expires

// Position management state
var int   posDir       = 0
var float entryPrice   = 0.0
var float runnerStop   = 0.0
var float posRisk      = 0.0
var int   posShares    = 0
var int   lockShares   = 0
var bool  lockDone     = false
var int   entryBarIdx  = 0

// ============================================================================
// TREND DETECTION
// ============================================================================

trendDir = 0
if close > ema20 and ema20 > ema50
    trendDir := 1
else if close < ema20 and ema20 < ema50
    trendDir := -1

// ============================================================================
// TOUCH → BOUNCE → SIGNAL CHAIN
// ============================================================================

// Only scan when flat and allowed to trade
canScan = strategy.position_size == 0 and not pastEntry and not dailyLimitHit and not na(atrVal) and atrVal > 0

if canScan
    // Step 1: Check for TOUCH on this bar
    if trendDir != 0
        tol = atrVal * touchTol
        isTouchLong  = trendDir == 1 and low <= ema20 + tol and low >= ema20 - atrVal * touchBelow
        isTouchShort = trendDir == -1 and high >= ema20 - tol and high <= ema20 + atrVal * touchBelow

        if isTouchLong or isTouchShort
            touchBar  := bar_index
            touchHigh := high
            touchLow  := low
            touchATR  := atrVal
            touchDir  := trendDir

    // Step 2: Check for BOUNCE (bar after touch)
    if touchBar >= 0 and bar_index == touchBar + 1
        bouncedLong  = touchDir == 1 and close > touchHigh
        bouncedShort = touchDir == -1 and close < touchLow

        if bouncedLong or bouncedShort
            bounceBar := bar_index

            if touchDir == 1
                signalPrice := touchHigh + signalOffset
                stopPrice   := touchLow - stopBuffer * touchATR
            else
                signalPrice := touchLow - signalOffset
                stopPrice   := touchHigh + stopBuffer * touchATR

            tradeRisk    := math.abs(signalPrice - stopPrice)
            signalDir    := touchDir
            signalExpiry := bar_index + signalBars
        else
            touchBar := -1  // bounce failed, reset

    // Step 3: Check SIGNAL TRIGGER (bars after bounce)
    if signalDir != 0 and bar_index > bounceBar and bar_index <= signalExpiry
        triggered = false

        if signalDir == 1 and high >= signalPrice
            triggered := true
        else if signalDir == -1 and low <= signalPrice
            triggered := true

        if triggered and tradeRisk > 0
            // Direction filter
            dirOk = (tradeDir == "Both") or (tradeDir == "Long Only" and signalDir == 1) or (tradeDir == "Short Only" and signalDir == -1)

            if dirOk
                // Position sizing
                qty = math.max(1, math.floor(strategy.equity * riskPct / 100 / tradeRisk))
                maxQty = math.max(1, math.floor(strategy.equity * maxPosPct / 100 / signalPrice))
                qty := math.min(qty, maxQty)

                // Execute entry
                posDir      := signalDir
                entryPrice  := signalPrice
                runnerStop  := stopPrice
                posRisk     := tradeRisk
                posShares   := qty
                lockShares  := math.max(1, math.floor(qty * lockPct / 100))
                lockDone    := false
                entryBarIdx := bar_index

                if signalDir == 1
                    strategy.entry("Long", strategy.long, qty=qty, stop=signalPrice)
                else
                    strategy.entry("Short", strategy.short, qty=qty, stop=signalPrice)

            // Reset signal regardless
            signalDir := 0
            touchBar  := -1

    // Expire signal
    if signalDir != 0 and bar_index > signalExpiry
        signalDir := 0
        touchBar  := -1

// ============================================================================
// POSITION MANAGEMENT
// ============================================================================

if strategy.position_size != 0 and posDir != 0
    d       = posDir
    atr_    = atrVal > 0 ? atrVal : 0.01
    barsIn  = bar_index - entryBarIdx

    // 1. Force close at session end
    if pastClose
        strategy.close_all(comment="Session Close")
        posDir := 0

    // 2. Max hold time
    else if barsIn >= maxHoldBars
        strategy.close_all(comment="Max Hold")
        posDir := 0

    else
        // 3. Stop check
        stopped = (d == 1 and low <= runnerStop) or (d == -1 and high >= runnerStop)

        if stopped
            strategy.close_all(comment=lockDone ? "Chandelier" : "Stop")
            // Track daily R loss
            if posRisk > 0
                pnlEst = (runnerStop - entryPrice) * d * posShares
                if pnlEst < 0
                    dailyRLoss := dailyRLoss + math.abs(pnlEst) / (posShares * posRisk)
            posDir := 0

        else
            // 4. Lock: 20% at 0.3R
            if not lockDone
                lockTarget = d == 1 ? entryPrice + lockRR * posRisk : entryPrice - lockRR * posRisk
                lockHit = (d == 1 and high >= lockTarget) or (d == -1 and low <= lockTarget)

                if lockHit
                    // Close lock portion
                    closeQty = math.min(lockShares, math.abs(strategy.position_size) - 1)
                    if closeQty > 0
                        if d == 1
                            strategy.close("Long", qty=closeQty, comment="Lock 0.3R")
                        else
                            strategy.close("Short", qty=closeQty, comment="Lock 0.3R")

                    lockDone := true
                    // Move stop to breakeven
                    if d == 1
                        runnerStop := math.max(runnerStop, entryPrice)
                    else
                        runnerStop := math.min(runnerStop, entryPrice)

            // 5. Chandelier trail (after lock, after enough bars)
            if lockDone and barsIn >= chandBars
                if d == 1
                    hh = ta.highest(high, chandBars)
                    newStop = hh - chandMult * atr_
                    runnerStop := math.max(runnerStop, newStop)
                else
                    ll = ta.lowest(low, chandBars)
                    newStop = ll + chandMult * atr_
                    runnerStop := math.min(runnerStop, newStop)

// Reset when flat
if strategy.position_size == 0 and posDir != 0
    posDir := 0

// ============================================================================
// CHART
// ============================================================================

// EMAs
plot(ema20, "EMA 20", color=color.orange, linewidth=2)
plot(ema50, "EMA 50", color=color.new(color.blue, 30), linewidth=1)

// Entry/Exit markers
longEntry  = strategy.position_size > 0 and strategy.position_size[1] <= 0
shortEntry = strategy.position_size < 0 and strategy.position_size[1] >= 0
plotshape(longEntry,  "Long",  shape.triangleup,   location.belowbar, color.green, size=size.normal)
plotshape(shortEntry, "Short", shape.triangledown, location.abovebar, color.red,   size=size.normal)

// Touch dots
isTouchVis = canScan and ((trendDir == 1 and low <= ema20 + atrVal * touchTol and low >= ema20 - atrVal * touchBelow) or (trendDir == -1 and high >= ema20 - atrVal * touchTol and high <= ema20 + atrVal * touchBelow))
plotshape(isTouchVis, "Touch", shape.circle, location.absolute, color.new(color.yellow, 20), size=size.tiny, offset=0)

// Active stop line
hasPos = strategy.position_size != 0 and posDir != 0
plot(hasPos ? runnerStop : na, "Stop", color=lockDone ? color.lime : color.red, linewidth=2, style=plot.style_linebr)
plot(hasPos ? entryPrice : na, "Entry", color=color.new(color.white, 40), linewidth=1, style=plot.style_linebr)

// Signal line (pending order)
hasSig = signalDir != 0 and bar_index <= signalExpiry
plot(hasSig ? signalPrice : na, "Signal Line", color=color.new(color.aqua, 0), linewidth=1, style=plot.style_linebr)

// Trend background
trendBg = trendDir == 1 ? color.new(color.green, 94) : trendDir == -1 ? color.new(color.red, 94) : na
bgcolor(trendBg, title="Trend")

// Daily limit warning
bgcolor(dailyLimitHit ? color.new(color.orange, 85) : na, title="Daily Limit")

// ============================================================================
// INFO PANEL
// ============================================================================

var table info = table.new(position.top_right, 2, 8,
     bgcolor=color.new(color.black, 80),
     border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    table.cell(info, 0, 0, "Trend",     text_color=color.white, text_size=size.small)
    table.cell(info, 1, 0, trendDir == 1 ? "BULL" : trendDir == -1 ? "BEAR" : "FLAT",
         text_color=trendDir == 1 ? color.green : trendDir == -1 ? color.red : color.gray, text_size=size.small)

    table.cell(info, 0, 1, "Position",  text_color=color.white, text_size=size.small)
    table.cell(info, 1, 1, strategy.position_size != 0 ? str.tostring(strategy.position_size) : "Flat",
         text_color=strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray, text_size=size.small)

    table.cell(info, 0, 2, "Lock",      text_color=color.white, text_size=size.small)
    table.cell(info, 1, 2, lockDone ? "Done (BE)" : "Pending", text_color=lockDone ? color.lime : color.yellow, text_size=size.small)

    table.cell(info, 0, 3, "Daily R",   text_color=color.white, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(dailyRLoss, "#.##") + " / " + str.tostring(dailyRLimit),
         text_color=dailyLimitHit ? color.red : color.white, text_size=size.small)

    table.cell(info, 0, 4, "ATR",       text_color=color.white, text_size=size.small)
    table.cell(info, 1, 4, str.tostring(atrVal, "#.##"), text_color=color.white, text_size=size.small)

    table.cell(info, 0, 5, "Signal",    text_color=color.white, text_size=size.small)
    table.cell(info, 1, 5, signalDir != 0 ? str.tostring(signalPrice, "#.##") : "None",
         text_color=signalDir != 0 ? color.aqua : color.gray, text_size=size.small)

    table.cell(info, 0, 6, "Session",   text_color=color.white, text_size=size.small)
    table.cell(info, 1, 6, pastClose ? "Closed" : pastEntry ? "No Entry" : "Active",
         text_color=pastClose ? color.red : pastEntry ? color.yellow : color.green, text_size=size.small)

    table.cell(info, 0, 7, "Bars Held", text_color=color.white, text_size=size.small)
    table.cell(info, 1, 7, posDir != 0 ? str.tostring(bar_index - entryBarIdx) : "—",
         text_color=color.white, text_size=size.small)

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(longEntry,  "Long Entry",  "Plan F Long: EMA20 touch bounce")
alertcondition(shortEntry, "Short Entry", "Plan F Short: EMA20 touch bounce")
alertcondition(dailyLimitHit and not dailyLimitHit[1], "Daily Limit", "Daily R limit hit — no more entries")
